@page "/"

<div class="home-container" id="home-view" data-testid="home-view">
    <div class="user-greeting">
        <h1>Welcome @UserName</h1>
    </div>

    <div class="main-content">
        <QuickStatMotivation />
        <RecentStudyDecks />
        <PinnedDecks />
    </div>

    <div class="navigation-bar">
        <ViewSelectionBar />
    </div>
</div>

@code {
    [Parameter]
    public string UserName { get; set; } = "Guest";
}
